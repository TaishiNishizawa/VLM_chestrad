#!/bin/bash
#SBATCH -J radgraph_eval
#SBATCH -p gpu
#SBATCH --gpus=1
#SBATCH --cpus-per-task=6
#SBATCH --mem=32G
#SBATCH --time=01:00:00
#SBATCH --output=slurm/logs/radgraph_eval/%x_%j.out
#SBATCH --error=slurm/logs/radgraph_eval/%x_%j.out
#SBATCH --chdir=/gs/gsfs0/shared-lab/duong-lab/VLM_graphrag

set -euo pipefail
mkdir -p slurm/logs/radgraph_eval

echo "[$(date)] Job $SLURM_JOB_ID on $(hostname)"
echo "CWD=$(pwd)"
echo "CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-unset}"
nvidia-smi || true

# -------- environment --------
module load cuda/12.1
source /gs/gsfs0/hpc01/rhel8/apps/conda3/etc/profile.d/conda.sh
conda activate radgraph_eval

# optional: keep python prints streaming into slurm log
export PYTHONUNBUFFERED=1

# dataloader tuning
# export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK}
# export MKL_NUM_THREADS=${SLURM_CPUS_PER_TASK}
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1

# quick sanity: confirm package import path (should point into your repo src/)

# -------- run naming / outputs --------
RUN_ID=${SLURM_JOB_ID}
SAVE_DIR="artifacts/radgraph_eval/${RUN_ID}"
mkdir -p "$SAVE_DIR"

python -u scripts/radgraph_eval_script.py \
    --generated artifacts/report_gen_zeroshot/25764768/k3/generated_reports.json \
    --mimic_root "/gs/gsfs0/shared-lab/duong-lab/MIMIC" \
    --save_dir "$SAVE_DIR" 
echo "[$(date)] Done."